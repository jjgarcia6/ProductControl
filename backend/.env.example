# Backend — variables de entorno. Copia a backend/.env y rellena con valores reales.
# NUNCA commitees backend/.env con secretos reales.

# Django
DJANGO_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
DJANGO_ALLOWED_HOSTS=tu-servicio.run.app
# CORS: solo el dominio del frontend (Vercel). Coma-separado si hay varios.
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# Base de datos — Supabase (PostgreSQL). SOLO PostgreSQL: sin Auth/Realtime/Storage.
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Notificaciones (placeholders; se estrenan en sus fases)
RESEND_API_KEY=
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# Google Cloud Storage — destino de respaldos pg_dump (bucket privado)
GCP_PROJECT_ID=
GCS_BACKUP_BUCKET=
