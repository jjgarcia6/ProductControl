# Backend — variables de entorno. Copia a backend/.env y rellena con valores reales.
# NUNCA commitees backend/.env con secretos reales.

# Django
DJANGO_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
DJANGO_ALLOWED_HOSTS=tu-servicio.run.app
# CORS: solo el dominio del frontend (Vercel). Coma-separado si hay varios.
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# Auth / JWT (F1)
# Clave de firma dedicada de SimpleJWT. En producción: GCP Secret Manager.
# Si se deja vacía, cae a DJANGO_SECRET_KEY (solo aceptable en local).
JWT_SIGNING_KEY=
# Cookie del refresh token. SameSite=Lax si front y back comparten dominio raíz
# (subdominios); SameSite=None solo si quedan cross-site (requiere CSRF double-submit).
AUTH_COOKIE_SAMESITE=Lax
# Secure=true SIEMPRE en producción (HTTPS). En local http se deja false.
AUTH_COOKIE_SECURE=false
# Dominio de la cookie. Vacío en local; ".midominio.com" si se comparten subdominios.
AUTH_COOKIE_DOMAIN=
# Umbral de rate limit del login (formato django-ratelimit: "5/m", "100/h", ...).
LOGIN_RATELIMIT=5/m

# Base de datos — Supabase (PostgreSQL). SOLO PostgreSQL: sin Auth/Realtime/Storage.
# Usa la "Session pooler" (IPv4) de Supabase, no la conexión directa (IPv6-only):
#   postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Tests: NO usan Supabase (pytest-django crea/borra una base de test; el pooler no tiene
# CREATEDB). Levanta el Postgres local y apunta los tests a él (no toca este archivo):
#   docker compose -f docker-compose.dev.yml up -d
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres uv run pytest

# Notificaciones (placeholders; se estrenan en sus fases)
RESEND_API_KEY=
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# Google Cloud Storage — destino de respaldos pg_dump (bucket privado)
GCP_PROJECT_ID=
GCS_BACKUP_BUCKET=
